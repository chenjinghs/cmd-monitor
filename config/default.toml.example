# cmd-monitor 配置文件
# 复制此文件为 default.toml 并填入实际值
# cp config/default.toml.example config/default.toml

[general]
# 守护进程 PID 文件路径
pid_file = "/tmp/cmd-monitor.pid"
# 日志文件路径（空则只输出到控制台）
log_file = ""
# 日志级别
log_level = "INFO"

[feishu]
# 飞书应用凭证（从飞书开放平台获取）
app_id = ""
app_secret = ""
# 接收通知的用户 ID — 类型由 receive_id_type 决定
receiver_id = ""
# ID 类型: "open_id" / "union_id" / "user_id" / "email" / "chat_id"
# union_id 跨同一开发者的多个应用稳定;若遇到 "open_id cross app" 错误请改成 union_id
receive_id_type = "union_id"

[powershell]
# PowerShell 监控配置
enabled = true
# Transcript 文件路径（空则自动生成）
transcript_path = ""
# 空闲检测间隔（秒）
poll_interval = 5
# 空闲判定阈值（秒）
idle_threshold = 10
# 提示符模式（用于检测空闲）
prompt_pattern = "PS [A-Z]:\\\\>"

[inject]
# 指令注入方式: sendkeys 或 namedpipe
method = "sendkeys"
# 指令注入目标窗口（空则自动匹配）
target_window = ""
# 注入后等待时间（秒）
inject_delay = 0.5

[hooks]
# Hook 监控配置
enabled = true

[state]
# 防抖窗口（秒）— 短于此时间的空闲不触发通知
debounce_seconds = 10.0
# 通知冷却（秒）— 同一状态转换不重复通知的最小间隔
notification_cooldown = 60.0
# Token 长度（hex 字符,2..8）— 卡片标题前缀 [xxxx]
token_length = 4
# 飞书回复无 token 前缀时,是否回退到最近活跃的 session
fallback_to_last_active = true
# 会话 TTL(秒) — 超过此时间无活动的 session 自动清理
session_ttl = 1800

[hooks.claude]
# Claude Code hooks 配置
enabled = true
# hook 配置文件路径（.claude/settings.json）
config_path = ".claude/settings.json"
# 监听的事件类型
events = ["Notification", "Stop", "PermissionRequest"]

[hooks.copilot]
# GitHub Copilot CLI hooks 配置
enabled = true
# hook 配置文件路径（.github/hooks/）
config_dir = ".github/hooks"
# 监听的事件类型
events = ["sessionStart", "userPromptSubmitted", "preToolUse", "postToolUse"]

[auto_reply]
# 自动回复配置 — 超时后自动注入预设答案
# 启用后，hook 事件触发飞书通知时，若超时内未收到飞书回复，将自动注入预设答案
enabled = false
# 等待用户飞书回复的最大时间（秒）
timeout_seconds = 60.0
# 超时后自动注入的预设答案
default_answer = "y"
