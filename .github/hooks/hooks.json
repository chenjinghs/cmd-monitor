{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "powershell": "cmd-monitor copilot-hook-handler --event sessionStart",
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "powershell": "cmd-monitor copilot-hook-handler --event userPromptSubmitted",
        "timeoutSec": 30
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "powershell": "cmd-monitor copilot-hook-handler --event preToolUse",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "powershell": "cmd-monitor copilot-hook-handler --event postToolUse",
        "timeoutSec": 30
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "powershell": "cmd-monitor copilot-hook-handler --event sessionEnd",
        "timeoutSec": 30
      }
    ],
    "errorOccurred": [
      {
        "type": "command",
        "powershell": "cmd-monitor copilot-hook-handler --event errorOccurred",
        "timeoutSec": 30
      }
    ]
  }
}